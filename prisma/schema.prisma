generator client {
  provider = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN @map("Admin")
  SUPER_ADMIN
  HR
  MANAGER
  EMPLOYEE
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  HALF_DAY
  LATE
  REMOTE
  ON_LEAVE
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
}

model Company {
  id                 String     @id @default(auto()) @map("_id") @db.ObjectId
  name               String
  logo               String?
  email              String?
  phone              String?
  website            String?
  industryType       String?
  gstNumber          String?
  panNumber          String?
  cinNumber          String?
  country            String?
  state              String?
  city               String?
  zipCode            String?
  address            String?
  officeRadius       Float      @default(200) // in meters
  latitude           Float?
  longitude          Float?
  attendanceRules    String?
  shiftPolicies      String?
  planType           String     @default("Trial") // Trial, Pro, Enterprise
  employeeLimit      Int        @default(50)
  storageLimit       Float      @default(10) // in GB
  activeModules      String[]   @default(["ALL"])
  primaryColor       String?    @default("#1a365d")
  secondaryColor     String?    @default("#0f172a")
  themePreference    String?    @default("dark")
  status             String     @default("ACTIVE") // ACTIVE, SUSPENDED, DELETED, DELETION_PENDING
  deletionRequestedAt DateTime?
  
  users              User[]
  departments        Department[]
  holidays           Holiday[]
  
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt

  @@map("companies")
}

model Department {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  companyId String   @db.ObjectId
  company   Company  @relation(fields: [companyId], references: [id])
  users     User[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("departments")
}

model User {
  id              String    @id @default(auto()) @map("_id") @db.ObjectId
  name            String?
  email           String    @unique
  password        String
  role            UserRole  @default(EMPLOYEE)
  companyId       String?   @db.ObjectId
  company         Company?  @relation(fields: [companyId], references: [id])
  departmentId    String?   @db.ObjectId
  department      Department? @relation(fields: [departmentId], references: [id])
  profilePicture  String?
  
  // Salary Structure
  basicSalary     Float     @default(0)
  hra             Float     @default(0)
  allowances      Float     @default(0)
  pf              Float     @default(0)
  esi             Float     @default(0)
  tax             Float     @default(0)
  professionalTax Float     @default(0)

  // Settings
  biometricEnabled Boolean  @default(false)
  faceIdEnabled    Boolean  @default(false)
  pushToken        String?
  
  attendances       Attendance[]
  leaves            Leave[]
  payrolls          Payroll[]
  authenticators    Authenticator[]
  loginHistory      LoginHistory[]
  notifications     Notification[]
  sentMessages      Message[]      @relation("SentMessages")
  receivedMessages  Message[]     @relation("ReceivedMessages")
  dailyJds          DailyJd[]
  
  // Onboarding relations
  employeeProfile   EmployeeProfile?
  payrollProfile    PayrollProfile?
  attendanceProfile AttendanceProfile?
  documents         Document[]
  auditLogs         AuditLog[]
  
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@map("users")
}

model Attendance {
  id              String    @id @default(auto()) @map("_id") @db.ObjectId
  userId          String    @db.ObjectId
  user            User      @relation(fields: [userId], references: [id])
  companyId       String?   @db.ObjectId
  date            DateTime  @default(now())
  checkIn         DateTime?
  checkOut        DateTime?
  status          AttendanceStatus @default(PRESENT)
  latitude        Float?
  longitude       Float?
  isMockLocation  Boolean   @default(false)
  isVpnDetected   Boolean   @default(false)
  workHours       Float     @default(0)
  overtime        Float     @default(0)
  breakDuration   Float     @default(0) // in minutes
  selfieUrl       String?
  failedAttempt   Boolean   @default(false)
  errorMessage    String?

  @@map("attendances")
}

model Leave {
  id          String      @id @default(auto()) @map("_id") @db.ObjectId
  userId      String      @db.ObjectId
  user        User        @relation(fields: [userId], references: [id])
  companyId   String?     @db.ObjectId
  startDate   DateTime
  endDate     DateTime
  type        String      // e.g., Sick, Casual, Annual
  reason      String?
  status      LeaveStatus @default(PENDING)
  approvedBy  String?     @db.ObjectId
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@map("leaves")
}

model Payroll {
  id              String    @id @default(auto()) @map("_id") @db.ObjectId
  userId          String    @db.ObjectId
  user            User      @relation(fields: [userId], references: [id])
  companyId       String?   @db.ObjectId
  month           Int
  year            Int
  basicSalary     Float
  hra             Float
  allowances      Float
  bonus           Float     @default(0)
  overtimePay     Float     @default(0)
  pf              Float
  esi             Float
  tax             Float
  professionalTax Float
  deductions      Float     @default(0)
  netSalary       Float
  status          String    @default("PENDING") // PENDING, PAID
  paidAt          DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@map("payrolls")
}

model Holiday {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  companyId String   @db.ObjectId
  company   Company  @relation(fields: [companyId], references: [id])
  date      DateTime
  name      String
  createdAt DateTime @default(now())

  @@map("holidays")
}

model Authenticator {
  id                   String   @id @default(auto()) @map("_id") @db.ObjectId
  credentialID         Bytes    @unique
  credentialPublicKey  Bytes
  counter              BigInt
  credentialDeviceType String
  credentialBackedUp   Boolean
  transports           String?
  userId               String   @db.ObjectId
  user                 User     @relation(fields: [userId], references: [id])

  @@map("authenticators")
}

model LoginHistory {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  user      User     @relation(fields: [userId], references: [id])
  ip        String?
  userAgent String?
  location  String?
  status    String   // SUCCESS, FAILED
  isTrusted Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("login_history")
}

model Notification {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  user      User     @relation(fields: [userId], references: [id])
  companyId String?  @db.ObjectId
  title     String
  message   String
  type      String   // INFO, WARNING, SUCCESS, ERROR
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("notifications")
}

model Message {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  senderId   String   @db.ObjectId
  sender     User     @relation("SentMessages", fields: [senderId], references: [id])
  receiverId String?  @db.ObjectId
  receiver   User?    @relation("ReceivedMessages", fields: [receiverId], references: [id])
  channelId  String?  @db.ObjectId
  content    String
  createdAt  DateTime @default(now())
  isRead     Boolean  @default(false)

  @@map("messages")
}

model Channel {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  isPrivate   Boolean  @default(false)
  memberIds   String[] @db.ObjectId
  creatorId   String   @db.ObjectId
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("channels")
}

model DailyJd {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  userId         String   @db.ObjectId
  user           User     @relation(fields: [userId], references: [id])
  companyId      String?  @db.ObjectId
  date           DateTime @default(now())
  tasksCompleted String
  tasksPending   String
  hoursWorked    Float
  remarks        String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("daily_jds")
}

model EmployeeProfile {
  id                     String    @id @default(auto()) @map("_id") @db.ObjectId
  userId                 String    @unique @db.ObjectId
  user                   User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  employeeId             String    @unique
  gender                 String
  dateOfBirth            DateTime
  mobileNumber           String
  alternatePhone         String?
  joiningDate            DateTime
  workLocation           String
  currentAddress         String
  permanentAddress       String
  bloodGroup             String
  emergencyContactName   String
  emergencyContactNumber String
  relationship           String
  maritalStatus          String
  nationality            String
  skills                 String[]  @default([])
  certifications         String[]  @default([])
  linkedin               String?
  github                 String?
  portfolio              String?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  @@map("employee_profiles")
}

model PayrollProfile {
  id                  String    @id @default(auto()) @map("_id") @db.ObjectId
  userId              String    @unique @db.ObjectId
  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  employeeCode        String    @unique
  panNumber           String
  aadhaarNumber       String
  uanNumber           String?
  pfNumber            String?
  esiNumber           String?
  bankName            String
  accountNumber       String
  ifscCode            String
  salaryStructure     String    @default("Standard")
  basicSalary         Float
  hra                 Float
  allowances          Float
  bonusEligibility    Boolean   @default(false)
  taxRegime           String    @default("NEW") // OLD, NEW
  overtimeRate        Float     @default(0)
  paymentFrequency    String    @default("MONTHLY") // MONTHLY, WEEKLY
  salaryEffectiveDate DateTime
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@map("payroll_profiles")
}

model AttendanceProfile {
  id                String    @id @default(auto()) @map("_id") @db.ObjectId
  userId            String    @unique @db.ObjectId
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignedOffice    String    @default("MumbaiHQ")
  shiftTiming       String    @default("09:00 - 18:00")
  weeklyOffs        String[]  @default(["Sunday"])
  overtimeEligible  Boolean   @default(false)
  remoteWorkAllowed Boolean   @default(false)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@map("attendance_profiles")
}

model Document {
  id         String    @id @default(auto()) @map("_id") @db.ObjectId
  userId     String    @db.ObjectId
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyId  String?   @db.ObjectId
  name       String    // e.g. "Aadhaar Card", "Resume"
  type       String    // file extension or category
  url        String
  size       Int
  uploadedAt DateTime  @default(now())
  expiryDate DateTime?
  status     String    @default("VERIFIED") // PENDING, VERIFIED, EXPIRED

  @@map("documents")
}

model AuditLog {
  id        String    @id @default(auto()) @map("_id") @db.ObjectId
  userId    String?   @db.ObjectId
  user      User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  companyId String?   @db.ObjectId
  action    String    // e.g. "ONBOARD_EMPLOYEE", "UPDATE_PAYROLL"
  details   String
  ip        String?
  userAgent String?
  createdAt DateTime  @default(now())

  @@map("audit_logs")
}

model RolePermission {
  id        String    @id @default(auto()) @map("_id") @db.ObjectId
  companyId String?   @db.ObjectId
  role      String    // SUPER_ADMIN, ADMIN, HR, MANAGER, EMPLOYEE
  module    String    // e.g. "EMPLOYEES", "PAYROLL", "LEAVES"
  canCreate Boolean   @default(false)
  canRead   Boolean   @default(false)
  canUpdate Boolean   @default(false)
  canDelete Boolean   @default(false)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@map("role_permissions")
}
